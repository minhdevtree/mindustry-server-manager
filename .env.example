# Mindustry game version (number only, no "v" prefix)
GAME_V=155

# Admin panel users (format: user:password:role,user2:password2:role2)
# Roles: admin (full access), mod (limited), viewer (read-only)
USERS=admin:changeme:admin,mod1:modpass:mod,viewer1:viewpass:viewer

# Docker container name for the Mindustry server
CONTAINER_NAME=mindustry-server

# Path to server log file (inside admin container)
LOG_PATH=/logs/log-0.txt

# Admin panel port (host:container)
ADMIN_PORT=9125
